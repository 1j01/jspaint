  "dependencies": {
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "idb": "^8.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@1j01/live-server": "^1.3.1",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/jquery": "^3.5.33",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@types/youtube": "^0.1.2",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "cspell-cli": "^9.2.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "glob": "^11.0.3",
    "globals": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "os-gui": "0.7.3",
    "prettier": "^3.7.4",
    "rtlcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.1.9",
    "vite-plugin-static-copy": "^3.1.3"
  },
  "scripts": {
    "lint-cspell": "cspell-cli lint .",
    "lint-tsc": "tsc --noEmit --project jsconfig.json",
    "lint-tsc-react": "tsc --noEmit --project tsconfig.json",
    "lint-eslint": "eslint",
    "lint": "npm-run-all --continue-on-error --serial lint-*",
    "format": "prettier --write \"src/react/**/*.{ts,tsx,js,jsx}\" \"src/new/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/react/**/*.{ts,tsx,js,jsx}\" \"src/new/**/*.{ts,tsx,js,jsx}\" \"tests/**/*.ts\"",
    "format:legacy": "eslint --fix --fix-type layout",
    "build-css": "rtlcss styles/layout.css styles/layout.rtl.css && rtlcss lib/os-gui/build/layout.css lib/os-gui/build/layout.rtl.css && rtlcss lib/98.css/98.custom-build.css lib/98.css/98.custom-build.rtl.css",
    "watch-css": "onchange --initial --poll 100 \"styles/layout.css\" \"lib/os-gui/build/layout.css\" \"lib/98.css/98.custom-build.css\" -- npm run build-css",
    "update-localization": "node ./localization/preprocess.js",
    "sync-os-gui": "node ./sync-package.js os-gui && git apply --ignore-whitespace ./lib/os-gui.patch && npm run build-css",
    "dev": "run-p watch-css dev:vite",
    "dev:vite": "vite --host 0.0.0.0 --port=1999",
    "build": "npm-run-all build-css build:vite",
    "build:vite": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port=4173",
    "test:start-server": "vite --port=11822",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:update-snapshots": "playwright test --update-snapshots",
    "sloc": "node scripts/calc-sloc.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/evgenyvinnik/mcpaint.git"
  },
  "bugs": {
    "url": "https://github.com/evgenyvinnik/mcpaint/issues"
  }
}
